{
  "General": {
    "Logging": {
      "LogLevel": {
        "Default": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "DataEngineRepositoryBaseUrl": "http://localhost",
    "CustomerDomainUrl": "https://mm-software.com",
    "HeaderSanitization": {
      "MaxHeaderSize": 8192,
      "MaxHeaderNameSize": 256,
      "AllowedCharacters": {
        "HeaderNames": "^[a-zA-Z0-9\\-_]+$",
        "HeaderValues": "^[\\x20-\\x7E]+$"
      },
      "BlockedPatterns": [
        "\\r|\\n",
        "\\x00",
        "<script"
      ]
    },
    "AllowedHosts": "*",
    "OpenTelemetry": {
      "OtlpEndpoint": "http://localhost:4317",
      "ServiceName": "TwinEngine",
      "ServiceVersion": "1.0.0"
    },
    "Serilog": {
      "Using": [
        "Serilog.Sinks.Console"
      ],
      "MinimumLevel": {
        "Default": "Warning",
        "Override": {
          "Microsoft": "Warning",
          "System": "Error"
        }
      },
      "WriteTo": [
        {
          "Name": "Console"
        }
      ]
    }
  },
  "Plugins": {
    "SubmodelElementIndexContextPrefix": "_aastwinengineindex_",
    "MultiLanguageProperty": {
      "DefaultLanguages": [
        "de",
        "en"
      ],
      "SemanticPostfixSeparator": "_"
    },
    "ResiliencePolicies": {
      "Retry": {
        "MaxRetryAttempts": 2,
        "DelayInSeconds": 4,
        "BackoffMultiplier": 2.0
      }
    },
    "Instances": [
      {
        "Name": "Plugin1",
        "baseUrl": "http://localhost:8086",
        "healthEndpoint": "/healthz",
        "headerMappings": [
          {
            "source": "Authorization",
            "target": "X-Auth-Token",
            "required": false
          },
          {
            "source": "X-Organization-Id",
            "target": "X-Tenant-Context",
            "required": false
          }
        ]
      }
    ]
  },
  "TemplateManagement": {
    "ResiliencePolicies": {
      "Retry": {
        "MaxRetryAttempts": 2,
        "DelayInSeconds": 4,
        "BackoffMultiplier": 2.0
      }
    },
    "TemplateMappingRules": {
      "SubmodelTemplateMappings": [
        {
          "templateId": "https://admin-shell.io/idta/SubmodelTemplate/DigitalNameplate/3/0",
          "pattern": [ "Nameplate" ]
        },
        {
          "templateId": "https://admin-shell.io/idta/SubmodelTemplate/CarbonFootprint/1/0",
          "pattern": [ "CarbonFootprint" ]
        },
        {
          "templateId": "https://admin-shell.io/idta/SubmodelTemplate/ContactInformation/1/0",
          "pattern": [ "ContactInformation" ]
        }
      ],
      "ShellTemplateMappings": [
        {
          "templateId": "https://mm-software.com/aas/aasTemplate",
          "pattern": [ "" ]
        }
      ],
      "AasIdExtractionRules": [
        {
          "Strategy": "Split",
          "Pattern": "/",
          "Index": 5
        }
      ]
    },
    "Semantics": {
      "InternalSemanticId": "InternalSemanticId"
    },
    "AasTemplateRepository": {
      "Name": "AasTemplateRepository",
      "baseUrl": "http://localhost:8081",
      "healthEndpoint": "/actuator/health",
      "headerMappings": [
        {
          "source": "Authorization",
          "target": "Authorization",
          "required": false
        },
        {
          "source": "X-User-Roles",
          "target": "X-Template-Access-Roles",
          "required": false
        }
      ]
    },
    "SubmodelTemplateRepository": {
      "Name": "SubmodelTemplateRepository",
      "baseUrl": "http://localhost:8081",
      "healthEndpoint": "/actuator/health",
      "headerMappings": []
    },
    "ConceptDescriptionTemplateRepository": {
      "Name": "ConceptDescriptionTemplateRepository",
      "baseUrl": "http://localhost:8081",
      "healthEndpoint": "/actuator/health",
      "headerMappings": []
    },
    "AasTemplateRegistry": {
      "Name": "AasTemplateRegistry",
      "baseUrl": "http://localhost:8082",
      "healthEndpoint": "/actuator/health",
      "headerMappings": [
        {
          "source": "Authorization",
          "target": "Authorization",
          "required": false
        }
      ]
    },
    "SubmodelTemplateRegistry": {
      "Name": "SubmodelTemplateRegistry",
      "baseUrl": "http://localhost:8083",
      "healthEndpoint": "/actuator/health",
      "headerMappings": [
        {
          "source": "Authorization",
          "target": "Authorization",
          "required": false
        }
      ]
    }
  }
}
