{
  "ApiConfiguration": {
    "BasePath": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PluginConfig": {
    "Plugins": [
      {
        "PluginName": "Plugin1",
        "PluginUrl": "http://localhost:8086"
      }
    ]
  },
  "AasEnvironment": {
    "DataEngineRepositoryBaseUrl": "http://localhost",
    "AasEnvironmentRepositoryBaseUrl": "http://localhost:8081",
    "SubModelRepositoryPath": "submodels",
    "AasRegistryBaseUrl": "http://localhost:8082",
    "AasRegistryPath": "shell-descriptors",
    "SubModelRegistryBaseUrl": "http://localhost:8083",
    "SubModelRegistryPath": "submodel-descriptors",
    "AasRepositoryPath": "shells",
    "ConceptDescriptionPath": "concept-descriptions",
    "SubmodelRefPath": "submodel-refs",
    "CustomerDomainUrl": "https://mm-software.com"
  },
  "MultiPluginConflictOption": {
    "HandlingMode": "TakeFirst"
  },
  "AasxExportOptions": {
    "RootFolder": "aasx"
  },
  "TemplateMappingRules": {
    "SubmodelTemplateMappings": [
      {
        "templateId": "https://admin-shell.io/idta/SubmodelTemplate/DigitalNameplate/3/0",
        "pattern": [ "Nameplate" ]
      },
      {
        "templateId": "https://admin-shell.io/idta/SubmodelTemplate/CarbonFootprint/1/0",
        "pattern": [ "CarbonFootprint" ]
      },
      {
        "templateId": "https://admin-shell.io/idta/SubmodelTemplate/ContactInformation/1/0",
        "pattern": [ "ContactInformation" ]
      }
    ],
    "ShellTemplateMappings": [
      {
        "templateId": "https://mm-software.com/aas/aasTemplate",
        "pattern": [""]
      }
    ],
    "AasIdExtractionRules": [
      {
        "Pattern": "Split",
        "Index": 5,
        "Separator": "/"
      }
    ]
  },
  "Semantics": {
    "MultiLanguageSemanticPostfixSeparator": "_",
    "SubmodelElementIndexContextPrefix": "_aastwinengineindex_",
    "InternalSemanticId": "InternalSemanticId"
  },
  "MultiLanguageProperty": {
    "DefaultLanguages": ["de", "en"]
  },
  "HttpRetryPolicyOptions": {
    "TemplateProvider": {
      "MaxRetryAttempts": 2,
      "DelayInSeconds": 4
    },
    "PluginDataProvider": {
      "MaxRetryAttempts": 2,
      "DelayInSeconds": 4
    },
    "SubmodelDescriptorProvider": {
      "MaxRetryAttempts": 2,
      "DelayInSeconds": 4
    }
  },
  "HeaderForwarding": {
    "HeaderSanitization": {
      "MaxHeaderSize": 8192,
      "MaxHeaderNameSize": 256,
      "AllowedCharacters": {
        "HeaderNames": "^[a-zA-Z0-9\\-_]+$",
        "HeaderValues": "^[\\x20-\\x7E]+$"
      },
      "BlockedPatterns": [
        "\\r|\\n",
        "\\x00",
        "<script"
      ]
    },
    "HeaderMappings": {
      "TemplateRepository": [
        {
          "Source": "Authorization",
          "Target": "Authorization",
          "Required": false
        },
        {
          "Source": "X-User-Roles",
          "Target": "X-Template-Access-Roles",
          "Required": false
        }
      ],
      "TemplateRegistry": [
        {
          "Source": "Authorization",
          "Target": "Authorization",
          "Required": false
        }
      ],
      "Plugins": {
        "Plugin1": [
          {
            "Source": "Authorization",
            "Target": "X-Auth-Token",
            "Required": false
          },
          {
            "Source": "X-Organization-Id",
            "Target": "X-Tenant-Context",
            "Required": false
          }
        ]
      }
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317",
    "ServiceName": "TwinEngine",
    "ServiceVersion": "1.0.0"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
